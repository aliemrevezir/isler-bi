# Şablon — `cp .env.example .env` yapıp gerçek değerleri girin. .env git'e girmez.

# ===== Logo / META (MSSQL kaynak) — yalnız worker/beat kullanır =====
LOGO_SERVER=192.168.46.174
LOGO_PORT=1433
LOGO_USER=mert
LOGO_PASSWORD=__LOGO_SIFRESI__
LOGO_DB=LOGO
META_DB=META
LOGO_PERIOD=01
HISTORY_START_YEAR=2023

# ===== Postgres (platform DB: raw + derived + app) =====
PG_DB=isler
PG_USER=isler
PG_PASSWORD=isler_dev_pwd
PG_PORT=5432

# ===== Redis (Celery broker + backend) =====
REDIS_PORT=6379

# ===== Backend (FastAPI) =====
APP_JWT_SECRET=__UZUN_RASTGELE_SECRET__
APP_CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# ===== Docker servis portları =====
BACKEND_PORT=8000
FRONTEND_PORT=8080
