# PROD şablonu — VPS'te `cp .env.prod.example .env.prod` yapıp gerçek değerleri gir.
# .env.prod git'e GİRMEZ (.gitignore). Compose'a `--env-file .env.prod` ile verilir.

# ===== Logo / META (MSSQL kaynak) — yalnız worker/beat kullanır =====
# VPS Logo LAN'ına doğrudan erişemez. Ofisten gelen reverse-SSH tüneli docker gateway'e
# (172.28.0.1:1433) bağlanır; worker oraya bağlanır. Bkz. DEPLOY.md.
LOGO_SERVER=172.28.0.1
LOGO_PORT=1433
LOGO_USER=__LOGO_READONLY_USER__
LOGO_PASSWORD=__LOGO_SIFRESI__
LOGO_DB=LOGO
META_DB=META
LOGO_PERIOD=01
HISTORY_START_YEAR=2023

# ===== Postgres (platform DB) =====
PG_DB=isler
PG_USER=isler
# GÜÇLÜ şifre üret: openssl rand -base64 24
PG_PASSWORD=__GUCLU_DB_SIFRESI__
PG_PORT=5432

# ===== Redis =====
REDIS_PORT=6379

# ===== Backend (FastAPI) =====
# GÜÇLÜ secret üret: openssl rand -hex 32
APP_JWT_SECRET=__UZUN_RASTGELE_SECRET__
# Frontend Caddy arkasında; tek origin. Yine de doğru domain'i yaz.
APP_CORS_ORIGINS=https://rapor.veriz.co

# ===== Docker servis portları (hepsi 127.0.0.1'e bind; public erişim mevcut Caddy üzerinden) =====
# Frontend'e dış erişim `edge` ağı üzerinden Caddy ile olur; host portu sadece yerel debug için.
# 8080 VPS'te `dashboard-query` tarafından kullanılıyor → çakışmayı önlemek için 8091.
BACKEND_PORT=8000
FRONTEND_PORT=8091
